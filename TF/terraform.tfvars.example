# Copy to terraform.tfvars and fill in real values (terraform.tfvars is
# git-ignored by convention -- keep credentials out of version control).
morpheus_url      = "https://morpheus.example.local"
morpheus_username = "master-admin"
morpheus_password = "change-me"
morpheus_insecure = true

# Bootstrap admin created via the Morpheus API in each tenant (users.tf
# local-exec). The sub-tenant providers authenticate as these users
# (subdomain\username) to resolve tenant-local roles.
coke_admin_username  = "coke-admin"
coke_admin_password  = "change-me"
pepsi_admin_username = "pepsi-admin"
pepsi_admin_password = "change-me"

# Bootstrap admin for the Coke-provider-created sub-tenant Coke-Finance
# (created via the Morpheus API in users.tf, same pattern as coke-admin).
coke_finance_admin_username = "coke-finance-admin"
coke_finance_admin_password = "change-me"

# SSH password for the existing hosts added to the Coke HVM Cluster (clusters.tf).
coke_finance_hvm_ssh_password = "change-me"

# ID of the cluster layout for the Coke HVM Cluster (clusters.tf). v1.5.0 has no
# cluster-layout data source; look the id up with:
#   GET /api/library/cluster-layouts?phrase=HVM
coke_hvm_layout_id = 0

# Set true to create the Coke Finance HVM Cloud 1 and its HVM cluster
# (clouds.tf/clusters.tf). Disabled by default.
create_coke_finance_hvm = false

# Management network interface on the Coke HVM Cluster hosts (clusters.tf).
# Must exist on every host; defaults to "ens160".
coke_hvm_management_net_interface = "ens160"

# iLO credentials for the Pepsi bare-metal (BMaaS) cloud (clouds.tf). Optional;
# leave empty to create the cloud without inline iLO credentials.
pepsi_baremetal_ilo_username = ""
pepsi_baremetal_ilo_password = ""

# Password applied to every generated tenant user (coke_user*/pepsi_user*).
user_password = "change-me"

# Number of standard users per tenant: coke_user[0-2], pepsi_user[0-4].
coke_user_count  = 3
pepsi_user_count = 5

# Coke tenant Active Directory identity source (identity_sources.tf). Disabled by
# default. Set create_coke_identity_source = true and fill in the connection
# details below (server, domain and binding credentials are required) to create
# it. AD users with no group mapping get the Coke tenant "tenant_user" role.
create_coke_identity_source = false
# coke_ad_name             = "Coke Active Directory"
# coke_ad_server           = "dc01.corp.example.com"
# coke_ad_domain           = "corp.example.com"
# coke_ad_binding_username = "svc-morpheus"
# coke_ad_binding_password = "change-me"
# coke_ad_use_ssl          = false
# Optional: restrict logins to members of a group (and, optionally, nested groups).
# coke_ad_required_group       = "Morpheus Users"
# coke_ad_search_member_groups = false
# coke_ad_description          = "Active Directory identity source for the Coke tenant."

# Per-tenant VMware (vCenter) cloud connection details. Each tenant gets its own
# infrastructure group and a VMware cloud assigned to it (clouds.tf).
coke_cloud_url        = "https://vcenter.example.local"
coke_cloud_datacenter = "Datacenter"
coke_cloud_cluster    = "Cluster"
coke_cloud_username   = "administrator@vsphere.local"
coke_cloud_password   = "change-me"

pepsi_cloud_url        = "https://vcenter.example.local"
pepsi_cloud_datacenter = "Datacenter"
pepsi_cloud_cluster    = "Cluster"
pepsi_cloud_username   = "administrator@vsphere.local"
pepsi_cloud_password   = "change-me"

# Git repository for the Coke tenant's Ansible integration (integrations.tf).
# The public Morpheus sample repo below needs no credentials; point this at your
# own repo (and add auth on hpe_morpheus_integration_ansible.coke) for a private
# one. coke_ansible_branch is optional and defaults to "master".
coke_ansible_url = "https://github.com/gomorpheus/morpheus-ansible.git"
# coke_ansible_branch = "master"

# Id of the VMware "Ubuntu 20.04" node type, bound to the "Coke Ubuntu 20.04
# Layout" (instance_types.tf). Required: Morpheus ships one "Ubuntu 20.04" node
# type per technology, so it must be selected by id rather than name. See the
# comment on variable "ubuntu_2004_node_type_id" in variables.tf for a curl
# snippet that lists the candidates and their provision type; use the "vmware"
# one. The example value below is illustrative -- replace it with your id.
ubuntu_2004_node_type_id = 0

# Default cloud-init credentials injected into provisioned Linux instances
# (settings.tf / hpe_morpheus_setting_provisioning).
cloudinit_username = "cloud-user"
cloudinit_password = "change-me"
